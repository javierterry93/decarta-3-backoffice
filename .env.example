# Conector de persistencia (registrado en src/config/database.config.ts)
# localStorage = adaptador database/localStorage (por defecto)
# supabase     = adaptador database/supabase
# remote       = HTTP contra openapi.yml (sin conector)
VITE_MENU_API=localStorage

# Base URL del backend (solo remote)
VITE_API_BASE_URL=/api

# Proxy de Vite en desarrollo (solo npm run dev)
VITE_API_PROXY_TARGET=http://localhost:3000

# Motor Supabase (solo VITE_MENU_API=supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_STORAGE_BUCKET=menu-images
