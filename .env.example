# Supabase (src/config/database.config.ts)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Alternativa en Supabase Docker (cuando SUPABASE_PUBLISHABLE_KEY está vacío):
# VITE_SUPABASE_ANON_KEY=eyJ...
VITE_SUPABASE_STORAGE_BUCKET=imageStore

# Supabase SQL (ejecutar en SQL Editor):
#   src/database/impl/supabase/schema.sql  (tablas + bucket imageStore)
# Seguridad RLS (dos apps):
#   • Cliente (anon): solo SELECT en vista snapshot_data por business_id.
#   • Backoffice (authenticated): CRUD directo en tablas (sin vista).
#   • Usuario business: dueño del negocio (owner_user_id) → solo su carta.
#   • Admin: app_metadata.role = "admin" en Authentication → Users → acceso total.
# Asignar rol admin con la API de Supabase o el dashboard (app_metadata, no user_metadata).
# En Supabase (o Docker .env): JWT_EXPIRY=14400

# Supabase local (Docker): copiar .env.docker o ejecutar npm run dev:docker
# VITE_SUPABASE_URL=http://localhost:8000
